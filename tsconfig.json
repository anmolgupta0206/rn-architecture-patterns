{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@features/*": [
        "patterns/01-modular-architecture/src/features/*"
      ],
      "@shared/*": [
        "patterns/01-modular-architecture/src/shared/*"
      ],
      "@app/*": [
        "patterns/01-modular-architecture/src/app/*"
      ]
    }
  },
  "include": [
    "patterns/**/*.ts",
    "patterns/**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}
